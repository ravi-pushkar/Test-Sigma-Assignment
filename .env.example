# Preferred LLM provider: Anthropic (prepaid credits). Takes precedence when set.
ANTHROPIC_API_KEY=
# Model for LLM stages; claude-sonnet-5 recommended for reliable crawls, claude-haiku-4-5 is cheapest.
ANTHROPIC_MODEL=claude-sonnet-5
# Fallback LLM provider used when no Anthropic key is set.
GEMINI_API_KEY=
# Gemini model used for LLM stages.
GEMINI_MODEL=gemini-flash-latest
# Seconds between LLM calls; raise to 45 on the free tier.
GEMINI_MIN_INTERVAL=10
# Neo4j Bolt connection URI.
NEO4J_URI=bolt://localhost:7687
# Neo4j username.
NEO4J_USER=neo4j
# Neo4j password; blank uses the local development default.
NEO4J_PASSWORD=
